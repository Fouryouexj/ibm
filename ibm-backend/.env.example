# ─── Database ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ibm_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=8h

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Frontend URL (for CORS) ──────────────────────────────
CLIENT_URL=http://localhost:3000
